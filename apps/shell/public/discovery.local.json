{
  "schema": "https://raw.githubusercontent.com/awslabs/frontend-discovery/main/schema/v1-pre.json",
  "microFrontends": {
    "widget-filter": [
      {
        "url": "http://localhost:5004/remoteEntry.js",
        "fallbackUrl": "http://localhost:5004/remoteEntry.js",
        "metadata": {
          "integrity": "",
          "version": "1.0.0"
        },
