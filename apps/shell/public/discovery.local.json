{
  "schema": "https://raw.githubusercontent.com/awslabs/frontend-discovery/main/schema/v1-pre.json",
  "microFrontends": {
    "widget-kpi": [
      {
        "url": "http://localhost:5001/remoteEntry.js",
        "fallbackUrl": "http://localhost:5001/remoteEntry.js",
        "metadata": {
          "integrity": "",
          "version": "1.0.0"
        },
        "deployment": {
          "default": true,
          "traffic": 90
        },
        "extras": {
          "module": "./mount",
          "slots": [{ "slot": "main" }],
          "route": "/overview",
          "requiredPermissions": ["dashboard.view"]
        }
      },
      {
        "url": "http://localhost:5002/remoteEntry.js",
        "fallbackUrl": "http://localhost:5002/remoteEntry.js",
        "metadata": {
          "integrity": "",
          "version": "1.1.0"
        },
        "deployment": {
          "default": false,
          "traffic": 10
        },
        "extras": {
          "module": "./mount",
          "slots": [{ "slot": "main" }],
          "route": "/overview",
          "requiredPermissions": ["dashboard.view"]
        }
      }
    ],
    "widget-trends": [
      {
        "url": "http://localhost:5003/remoteEntry.js",
        "fallbackUrl": "http://localhost:5003/remoteEntry.js",
        "metadata": {
          "integrity": "",
          "version": "1.0.0"
        },
        "deployment": {
          "default": true,
          "traffic": 100
        },
        "extras": {
          "module": "./mount",
          "slots": [{ "slot": "side" }],
          "route": "/overview",
          "requiredPermissions": ["dashboard.view"]
        }
      }
    ],
    "widget-filter": [
      {
        "url": "http://localhost:5004/remoteEntry.js",
        "fallbackUrl": "http://localhost:5004/remoteEntry.js",
        "metadata": {
          "integrity": "",
          "version": "1.0.0"
        },
        "deployment": {
          "default": true,
          "traffic": 100
        },
        "extras": {
          "module": "./mount",
          "slots": [
            { "slot": "toolbar", "variant": "full" },
            { "slot": "side", "variant": "mini" }
          ],
          "route": "/overview",
          "requiredPermissions": ["dashboard.view"]
        }
      }
    ],
    "widget-admin": [
      {
        "url": "http://localhost:5005/remoteEntry.js",
        "fallbackUrl": "http://localhost:5005/remoteEntry.js",
        "metadata": {
          "integrity": "",
          "version": "1.0.0"
        },
        "deployment": {
          "default": true,
          "traffic": 100
        },
        "extras": {
          "module": "./mount",
          "slots": [{ "slot": "main" }],
          "route": "/admin",
          "requiredPermissions": ["dashboard.admin"]
        }
      }
    ]
  }
}
