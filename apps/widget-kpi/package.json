{
  "name": "widget-kpi",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.config.v1-0-0.js && vite build --config vite.config.v1-1-0.js",
    "build:v1-0-0": "vite build --config vite.config.v1-0-0.js",
    "build:v1-1-0": "vite build --config vite.config.v1-1-0.js",
    "preview": "vite preview --config vite.config.v1-0-0.js --port 5001",
    "preview:v1-1-0": "vite preview --config vite.config.v1-1-0.js --port 5002",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@demo/contracts": "workspace:*",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6",
    "happy-dom": "^20.10.6",
    "vite": "^8",
    "vitest": "^4.1.10"
  }
}
